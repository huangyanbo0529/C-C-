{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "colcon build", // 和launch.json里的preLaunchTask完全对应
            "type": "shell",
            // "command": "colcon build --symlink-install", // 构建工作空间下所有功能包
            "command": "colcon build --symlink-install --packages-select cpp01_test py01_test",
            // 👉 上面的demo_py_pkg替换为你的包名，多个包用空格分隔
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}